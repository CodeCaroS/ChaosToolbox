    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "markdown-text-editor": "^1.4.0",
    "markdownlint": "^0.41.0",
    "mermaid": "^11.15.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
